FROM ubuntu:25.04

ENV DEBIAN_FRONTEND=noninteractive

# Packages for installing and running ppt
RUN apt-get update -qq && apt-get install -y \
    adduser \
    bash \
    ca-certificates \
    curl \
    tar \
    gzip \
    sudo \
    python3 

# Packages for compiling C source packages
RUN apt-get install -y coreutils sed git build-essential lowdown git make gcc g++ locales

RUN adduser --disabled-password --gecos '' user

# Passwordless sudo for exploratory sandboxing.
RUN usermod -aG sudo user \
  && printf 'user ALL=(ALL) NOPASSWD:ALL\n' >/etc/sudoers.d/user \
  && chmod 0440 /etc/sudoers.d/user

USER user
ENV HOME=/home/user
WORKDIR $HOME

# Use a locally-built release asset from the mounted workspace.
ENV PPT_INSTALL_ASSET_URL=file:///workspace/dist/ppt-sandbox-linux.tar.gz

# Mimic README install command, then drop into an interactive shell.
CMD ["bash", "-lc", "curl -fsSL file:///workspace/dist/install.sh | bash -s -- --shell-config yes && exec bash -li"]
