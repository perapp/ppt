FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y \
    adduser \
    bash \
    ca-certificates \
    curl \
    python3 

RUN adduser user
USER user
ENV HOME=/home/user
WORKDIR $HOME

COPY install.sh /tmp/
RUN cat /tmp/install.sh | bash

CMD ["bash"]
